# Telegram Bot API — token from @BotFather
TELEGRAM_BOT_TOKEN=
# Optional: must match secret_token passed to setWebhook; if set, incoming webhooks must send X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_WEBHOOK_SECRET=

# LLM (OpenAI cloud or OpenAI-compatible e.g. Ollama). Optional if USE_LLM=false
# Ollama (local): dummy key + base URL; set OPENAI_MODEL to a pulled model
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_MODEL=llama3.2
# Cloud OpenAI: set real OPENAI_API_KEY and omit or empty OPENAI_BASE_URL

# Server
PORT=3000

# Set to false to echo inbound text (useful before LLM is wired)
USE_LLM=true

# Optional: override default narrow customer-support style prompt
# AGENT_SYSTEM_PROMPT=
